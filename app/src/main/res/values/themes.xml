<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.WordTrigger" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/blue</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="containerColor">@color/black</item>
        <item name="colorSecondary">@color/white</item>
        <item name="colorOnSecondary">@color/blue</item>
        <item name="android:listSelector">@android:color/transparent</item>
        <item name="android:windowBackground">@color/black</item>
        <item name="colorTertiary">@color/blue</item>
        <item name="colorControlHighlight">#33FFFFFF</item>
    </style>

    <style name="ShapeAppearance.App.CircleImageView" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="CustomChipStyle" parent="Widget.MaterialComponents.Chip.Filter">
        <item name="chipBackgroundColor">@color/chip_bg_selector</item>
        <item name="android:textColor">@color/white</item>
        <item name="chipStrokeWidth">0dp</item>
        <item name="checkedIconVisible">false</item>
        <item name="closeIconTint">@color/white</item>
        <item name="rippleColor">@color/blue</item>
    </style>

    <style name="AlertDialogTheme" parent="Theme.Material3.DayNight.Dialog.Alert">
        <item name="android:windowBackground">@color/white</item>

    </style>

    <style name="Theme.WordTrigger" parent="Base.Theme.WordTrigger" />
</resources>